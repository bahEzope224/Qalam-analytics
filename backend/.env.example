# ============================================================
# Fichier d'exemple des variables d'environnement
# Copier en .env et adapter les valeurs avant de lancer l'app
# ============================================================

# --- Identité ---
APP_NAME="Analytics Platform API"
API_VERSION="v1"
ENV="development"   # development | staging | production

# --- Sécurité JWT ---
SECRET_KEY="changeme-use-openssl-rand-hex-32"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- Base de données PostgreSQL ---
DATABASE_URL="postgresql+asyncpg://user:password@localhost:5432/analytics_db"

# --- Google Analytics 4 ---
GA4_CREDENTIALS_PATH="credentials/ga4_service_account.json"
GA4_DEFAULT_PROPERTY_ID="properties/XXXXXXXXX"

# --- CORS ---
ALLOWED_ORIGINS='["http://localhost:3000","http://localhost:5173"]'
ALLOWED_HOSTS='["*"]'

# --- Redis (cache / Celery) ---
REDIS_URL="redis://localhost:6379/0"

# --- Celery ---
CELERY_BROKER_URL="redis://localhost:6379/0"
CELERY_RESULT_BACKEND="redis://localhost:6379/1"
CELERY_TIMEZONE="Europe/Paris"
# Rétention des snapshots en base (jours)
SNAPSHOT_RETENTION_DAYS=365
